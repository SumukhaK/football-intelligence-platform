# Normalize line endings to LF on commit
* text=auto eol=lf

# Force LF for source files
*.py text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.env text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Mark generated files as non-diffable
*.lock linguist-generated=true
